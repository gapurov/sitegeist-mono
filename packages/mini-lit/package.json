{
   "name": "@mariozechner/mini-lit",
   "version": "0.2.1",
   "description": "Lightweight Lit components with shadcn-inspired theming and Tailwind CSS integration",
   "author": "Mario Zechner",
   "type": "module",
   "main": "./dist/index.js",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "files": [
      "dist",
      "src/styles",
      "README.md",
      "llms.txt"
   ],
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js"
      },
      "./dist/*": "./dist/*",
      "./styles/*": "./src/styles/*"
   },
   "scripts": {
      "build": "vp exec tsc",
      "build:example": "vp run mini-lit-example#build",
      "dev": "concurrently -k -n \"mini-lit,example\" -c \"blue,magenta\" \"vp run @mariozechner/mini-lit#dev:tsc\" \"vp run @mariozechner/mini-lit#dev:example\"",
      "dev:tsc": "vp exec tsc --watch --preserveWatchOutput",
      "dev:example": "vp run mini-lit-example#dev",
      "check": "vp exec biome check . --write && vp exec tsc --noEmit && vp run mini-lit-example#check",
      "test": "vp test",
      "test:ui": "vp test --ui"
   },
   "dependencies": {
      "@preact/signals-core": "^1.12.1",
      "class-variance-authority": "^0.7.1",
      "diff": "^8.0.2",
      "highlight.js": "^11.11.1",
      "html-parse-string": "^0.0.9",
      "katex": "^0.16.22",
      "lucide": "^0.544.0",
      "marked": "^16.3.0",
      "tailwind-merge": "^3.3.1",
      "tailwind-variants": "^3.1.1",
      "uhtml": "^5.0.9"
   },
   "peerDependencies": {
      "lit": "^3.3.1"
   },
   "devDependencies": {
      "@anthropic-ai/claude-code": "^1.0.128",
      "@biomejs/biome": "^2.2.4",
      "@types/node": "^24.5.2",
      "@vitest/ui": "catalog:",
      "concurrently": "^9.2.1",
      "happy-dom": "^20.0.8",
      "prettier": "^3.6.2",
      "string-dedent": "^3.0.2",
      "tsx": "^4.20.5",
      "typescript": "^5.9.2",
      "vitest": "catalog:"
   }
}
